{
  "rewrites":[
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers":[
    {
      "source": "/(.*)",
      "headers":[
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        }
      ]
    },
    {
      "source": "/onnx-runtime/(.*)",
      "headers":[
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/tts-models/(.*)",
      "headers":[
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
